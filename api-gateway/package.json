{
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["plugins/**/*.js", "server.js"],
    "coverageThreshold": {
      "global": { "lines": 100, "functions": 100, "branches": 100, "statements": 100 }
    }
  },
  "dependencies": {
    "axios": "^1.18.0",
    "express-gateway": "^1.16.11",
    "opossum": "^9.0.0"
  },
  "devDependencies": {
    "axios-mock-adapter": "^2.1.0",
    "jest": "^30.4.2"
  }
}
